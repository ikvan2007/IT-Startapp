# Скопируйте в .env и заполните перед запуском docker compose

# Секрет для подписи JWT-токенов (обязательно поменяйте в production!)
JWT_SECRET=edu-platform-secret-change-me-in-production

# База данных SQLite
DATABASE_URL=file:./prisma/dev.db

# Redis — кэш и очередь задач
# Для локальной разработки: redis://localhost:6379
# В Docker Compose: redis://redis:6379
REDIS_URL=redis://localhost:6379

# Сколько дней хранить бэкапы (cron-контейнер)
BACKUP_KEEP_DAYS=7
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=4cb2663e-c646-417a-b80e-ba6ac7f0ff76
HCAPTCHA_SECRET_KEY=ES_760cc15bfaeb4234b51cdc6be5428881