{
  "name": "studytask",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db push && npx tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "db:migrate": "node migrations/migrate.mjs",
    "db:migrate:status": "node migrations/migrate.mjs --status",
    "backup": "bash scripts/backup.sh",
    "backup:test": "node scripts/test-backup-restore.mjs",
    "worker": "node src/workers/queue-worker.mjs",
    "test": "jest",
    "test:unit": "jest __tests__/unit --verbose",
    "test:integration": "jest __tests__/integration --verbose",
    "test:future": "jest __tests__/future.test.ts --verbose",
    "test:all": "jest --verbose",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2",
    "bull": "^4.16.5",
    "ioredis": "^5.4.2",
    "jose": "^5",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2",
    "@types/bull": "^4.10.4",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.2",
    "tsx": "^4",
    "typescript": "^5",
    "undici": "^8.4.1"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  }
}
